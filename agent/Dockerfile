FROM python:3.12-slim

WORKDIR /app

# Copy the agent source. Foundry's container build flattens this layer into
# an ext4 rootfs on /dev/vdb at microVM boot — see docs/architecture.md.
COPY . user_agent/
WORKDIR /app/user_agent

# Install from the pinned lock file (generated by `uv pip compile`).
# Because every transitive dependency is pinned with `==`, pip's resolver
# has zero work to do: it just downloads each pinned version in sequence.
#
# This avoids the `ResolutionTooDeep: 200000` failure mode that plain pip
# hits when resolving the `agent-framework[all]` umbrella from scratch on
# ACR remote builds (~15-19 minutes before failing).
#
# To refresh the lock locally:
#     uv pip compile agent/requirements.txt \
#         --prerelease=allow \
#         --python-version 3.12 \
#         --python-platform x86_64-unknown-linux-gnu \
#         --no-strip-extras \
#         --emit-index-url \
#         -o agent/requirements.lock
RUN if [ -f requirements.lock ]; then \
        pip install --no-cache-dir --no-deps -r requirements.lock; \
    else \
        echo "ERROR: requirements.lock missing — run 'uv pip compile' first" >&2; \
        exit 1; \
    fi

EXPOSE 8088

CMD ["python", "main.py"]
