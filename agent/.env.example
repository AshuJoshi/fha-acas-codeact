# Sample environment for the agent container's main.py.
# In production these values are injected by Foundry from agent.yaml's
# environment_variables block (which is in turn populated by `azd` from
# the active environment's .env at deploy time). This file exists only to
# show what main.py expects and to support local-laptop dry runs.

# Foundry project endpoint (e.g. https://<account>.services.ai.azure.com/api/projects/<project>)
FOUNDRY_PROJECT_ENDPOINT=

# Name of the Foundry model deployment (e.g. gpt-5.4)
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4

# Where the ACAS sandbox group lives
ACAS_SUBSCRIPTION_ID=
ACAS_RESOURCE_GROUP=
ACAS_SANDBOX_GROUP=
ACAS_LOCATION=westus2
ACAS_DISK=python-3.13

# Optional: lease timeout for the slow-path SandboxPool.lease() (seconds)
ACAS_LEASE_TIMEOUT_S=120

# Optional: pin a pre-allocated sandbox id (skips lease on every invocation)
# ACAS_SANDBOX_ID=
