{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName":       { "value": "${AZURE_ENV_NAME}" },
    "location":              { "value": "${AZURE_LOCATION=westus2}" },
    "foundryLocation":       { "value": "${AZURE_AI_FOUNDRY_LOCATION=eastus2}" },
    "principalId":           { "value": "${AZURE_PRINCIPAL_ID}" },
    "principalType":         { "value": "${AZURE_PRINCIPAL_TYPE=User}" },
    "foundryModelName":      { "value": "${AZURE_AI_MODEL_NAME=gpt-5.4}" },
    "foundryModelVersion":   { "value": "${AZURE_AI_MODEL_VERSION=2026-03-05}" },
    "foundryModelSkuName":   { "value": "${AZURE_AI_MODEL_SKU_NAME=GlobalStandard}" },
    "foundryModelCapacity":  { "value": "${AZURE_AI_MODEL_CAPACITY=10}" }
  }
}
